{
  "name": "@headwood/aik-mcp",
  "version": "0.0.1",
  "description": "MCP server for AI knowledge repository (rules, skills, workflows, agents, commands, templates)",
  "author": "openhoat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openhoat/aik-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/openhoat/aik-mcp/issues"
  },
  "homepage": "https://github.com/openhoat/aik-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "knowledge-base",
    "rules",
    "skills",
    "workflows",
    "agents",
    "templates",
    "llm",
    "opencode",
    "claude-code",
    "cline",
    "aik"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aik-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.9.2"
  },
  "volta": {
    "node": "22.13.0",
    "npm": "10.9.2"
  },
  "scripts": {
    "prepublishOnly": "npm run validate",
    "build": "tsc && cp -r src/built-in dist/built-in",
    "mcp:inspector": "npx @modelcontextprotocol/inspector tsx src/index.js",
    "qa": "npm run qa:biome && npm run qa:markdown",
    "qa:fix": "npm run qa:biome:fix && npm run qa:markdown:fix",
    "qa:biome": "biome check .",
    "qa:biome:fix": "biome check --write --unsafe .",
    "qa:markdown": "markdownlint-cli2",
    "qa:markdown:fix": "markdownlint-cli2 --fix",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "validate": "npm run qa && npm run build && npm run test",
    "postversion": "git push && git push --tags && echo 'GitHub Actions va publier automatiquement sur npm'",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "chokidar": "5.0.0",
    "fuse.js": "7.4.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@types/jest": "30.0.0",
    "@types/node": "26.0.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "markdownlint-cli2": "0.22.1",
    "ts-jest": "29.4.11",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
